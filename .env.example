# Copy to .env and fill in your Anthropic key.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# --- ClickHouse ---
# Option A: ClickHouse Cloud (free trial) - no install needed. From your Cloud
# service "Connect" panel, fill in host + password below:
CLICKHOUSE_HOST=<something>.clickhouse.cloud
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=<your cloud password>
CLICKHOUSE_DATABASE=demo
CLICKHOUSE_SECURE=true

# Option B: local Docker (defaults match docker-compose.yml). To use this
# instead, comment out Option A above and uncomment these:
#   CLICKHOUSE_HOST=localhost
#   CLICKHOUSE_PORT=8123
#   CLICKHOUSE_USER=default
#   CLICKHOUSE_PASSWORD=
#   CLICKHOUSE_DATABASE=demo
#   CLICKHOUSE_SECURE=false

# Model that writes the SQL. Haiku = fastest and cheapest (great for this task).
# Use claude-sonnet-4-6 or claude-opus-4-8 for tougher/ambiguous questions.
AGENT_MODEL=claude-haiku-4-5-20251001
